# Copy to .env and adjust to match your local PostgreSQL setup.

# Server
PORT=4000

# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=typeahead

# Redis connection (the cache store)
REDIS_URL=redis://localhost:6379

# Tunables (optional — sensible defaults are used if omitted)
CACHE_TTL_MS=300000        # 5 minutes
FLUSH_INTERVAL_SECONDS=30  # batch flush cadence
MAX_SUGGESTIONS=10
RECENCY_WEIGHT=3           # trending: fresh query boosted up to (1+W)x its count
TRENDING_MIN_COUNT=5       # trending: min searches before a query is eligible
