# Copy to .env and adjust to match your local PostgreSQL setup.

# Server
PORT=4000

# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=typeahead

# Tunables (optional — sensible defaults are used if omitted)
CACHE_TTL_MS=300000        # 5 minutes
FLUSH_INTERVAL_SECONDS=30  # batch flush cadence
MAX_SUGGESTIONS=10
